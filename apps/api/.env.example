DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public&sslmode=require"
# Restricted role WITHOUT bypassrls, used by the app at runtime so Postgres RLS
# actually applies (the primary/owner role above is used only for migrations —
# on managed Postgres it typically has BYPASSRLS and would make RLS a no-op).
# See prisma/migrations/*_enable_rls/migration.sql for how to create it:
#   CREATE ROLE elos_app LOGIN PASSWORD '...' NOBYPASSRLS;
#   GRANT USAGE ON SCHEMA public TO elos_app;
#   GRANT SELECT, INSERT, UPDATE, DELETE ON ALL TABLES IN SCHEMA public TO elos_app;
#   ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT SELECT, INSERT, UPDATE, DELETE ON TABLES TO elos_app;
RUNTIME_DATABASE_URL="postgresql://elos_app:password@host:5432/dbname?schema=public&sslmode=require"
JWT_SECRET="change-me-to-a-long-random-string"
WEB_ORIGIN="http://localhost:3000"
PORT=3001
# Powers the Elô assistant (chat + tool use / modo agente). https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
# Sends MFA login codes and password-reset links. Without this, both flows
# fall back to returning the code/link directly in the API response (dev-only
# behavior — see EmailService). https://resend.com/api-keys
RESEND_API_KEY="re_..."
EMAIL_FROM="Plataforma Elos <onboarding@resend.dev>"
